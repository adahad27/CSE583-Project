.vscode/
.env/
env/
inference.log
__pycache__/
*.pyc
*.pyo
*.pyd

# # Ignore everything by default
# /*

# # Allow directories to be scanned for contents
# !*/

# Whitelist PGO results directories
!*pgo_results/
!*pgo_results/**

# Whitelist unroll remarks directories
!*unroll_remarks/
!*unroll_remarks/**

# Whitelist individual bash scripts
!*.sh

# Whitelist essential project documentation and configuration
!context.md
!readme.md
!.gitignore

# Explicitly ignore benchmark repositories (they will be caught by /* anyway)
/PolyBenchC-4.2.1/
/embench-iot/
/llvm-test-suite/
/NPB3.0-omp-C/
/speccpu2017

# Ignore model artifacts, but keep evaluation outputs and run notes for specific runs
models/**
!models/**/
!models/**/eval_predictions.csv
!models/**/trainer_log_history.json


# Common build artifacts to ignore (backup safety)
*.o
*.a
*.so
*.dylib
*.exe
.DS_Store
.env
